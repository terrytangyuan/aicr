#!/bin/bash
set -euo pipefail

# =============================================================================
# E2E Integration Tests for aicr CLI
# =============================================================================
#
# PURPOSE:
# Builds the aicr binary and runs Chainsaw-based CLI integration tests.
# Tests are defined declaratively in tests/chainsaw/cli/ and tests/chainsaw/bundle-templates/.
#
# WHAT THIS SCRIPT DOES:
# 1. Builds the aicr binary via make build
# 2. Locates the platform-specific binary
# 3. Runs chainsaw test --no-cluster on tests/chainsaw/cli/ and tests/chainsaw/bundle-templates/
#
# PREREQUISITES:
# - chainsaw (brew install kyverno/tap/chainsaw)
# - make, goreleaser (for building)
#
# =============================================================================

# Dir setup
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "${DIR}/common"
ROOT=$(dirname "${DIR}")

# Check required tools
has_tools chainsaw make uname goreleaser

# ============================================================================
# BUILD
# ============================================================================

build_binary() {
  msg "Building aicr binary"

  cd "${ROOT}"

  if ! make build 2>&1; then
    err "Failed to build aicr binary"
  fi

  # Find the built binary (platform-specific)
  local os_name arch_name
  os_name=$(uname -s | tr '[:upper:]' '[:lower:]')
  arch_name=$(uname -m)

  # Convert arch name
  case "$arch_name" in
    x86_64) arch_name="amd64" ;;
    aarch64|arm64) arch_name="arm64" ;;
  esac

  # Try to find the binary with various naming patterns
  # goreleaser uses different suffixes:
  # - _v1 for amd64 (x86_64 microarchitecture level 1)
  # - _v8.0 for arm64 (ARMv8.0 baseline)
  AICR_BIN=""
  for pattern in \
    "${ROOT}/dist/aicr_${os_name}_${arch_name}/aicr" \
    "${ROOT}/dist/aicr_${os_name}_${arch_name}_v1/aicr" \
    "${ROOT}/dist/aicr_${os_name}_${arch_name}_v8.0/aicr" \
    "${ROOT}/dist/aicr_${os_name}_all/aicr"; do
    if [ -x "$pattern" ]; then
      AICR_BIN="$pattern"
      break
    fi
  done

  if [ -z "$AICR_BIN" ] || [ ! -x "$AICR_BIN" ]; then
    err "Built binary not found in dist/"
  fi

  msg "Using binary: ${AICR_BIN}"
  export AICR_BIN

  # Detect binary attestation (created by goreleaser cosign hook when SLSA_PREDICATE is set)
  ATTEST_FILE="$(dirname "$AICR_BIN")/aicr-attestation.sigstore.json"
  if [[ -f "$ATTEST_FILE" ]]; then
    export AICR_ATTESTED=true
    msg "Binary attestation found: ${ATTEST_FILE}"
  else
    export AICR_ATTESTED=false
    msg "No binary attestation found (attestation chainsaw tests will skip)"
  fi
}

# ============================================================================
# MAIN
# ============================================================================

msg "Starting E2E Integration Tests (Chainsaw)"

build_binary

export REPO_ROOT="${ROOT}"

msg "Running chainsaw tests (no-cluster CLI tests)"
chainsaw test \
  --no-cluster \
  --config "${ROOT}/tests/chainsaw/chainsaw-config.yaml" \
  --test-dir "${ROOT}/tests/chainsaw/cli/" \
  --selector 'ci!=true'

msg "Running chainsaw tests (bundle template tests)"
chainsaw test \
  --no-cluster \
  --config "${ROOT}/tests/chainsaw/chainsaw-config.yaml" \
  --test-dir "${ROOT}/tests/chainsaw/bundle-templates/"

msg "All tests passed!"
